# Database — SQLite for local dev, swap for PostgreSQL in production
# SQLite:     DATABASE_URL=sqlite:///./app.db
# PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/fantasy_pitchers
DATABASE_URL=sqlite:///./app.db

# Scheduler — time to run the daily pitcher refresh (24hr format, UTC)
REFRESH_HOUR=7
REFRESH_MINUTE=0

# CORS — React dev server origin
CORS_ORIGINS=http://localhost:5173
